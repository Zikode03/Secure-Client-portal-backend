{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=secure_client_portal;User=portal_user;Password=portal_password;"
  },
  "Jwt": {
    "Issuer": "SecureClientPortal",
    "Audience": "SecureClientPortal.Client",
    "SigningKey": "CHANGE_ME_TO_A_LONG_RANDOM_SIGNING_KEY",
    "ExpiresMinutes": 120
  },
  "Storage": {
    "Provider": "local",
    "LocalRoot": "storage/uploads"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
